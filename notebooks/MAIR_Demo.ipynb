   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 4: Run degradation detector on each image ─────────────\n",
    "test_images = [\n",
    "    ('noisy_input.png',    noisy_path),\n",
    "    ('lowlight_input.png', lowlight_path),\n",
    "    ('hazy_input.png',     hazy_path),\n",
    "    ('jpeg_input.png',     jpeg_path),\n",
    "]\n",
    "\n",
    "detection_results = {}\n",
    "for name, path in test_images:\n",
    "    result = detect_degradation(path)\n",
    "    detection_results[name] = result\n",
    "    print(f\"\\n{name}\")\n",
    "    print(f\"  Primary   : {result['primary']}  (conf={result['confidence']:.3f})\")\n",
    "    scores = {k: v for k, v in result['scores'].items() if k != 'image_size'}\n",
    "    for k, v in sorted(scores.items(), key=lambda x: -x[1]):\n",
    "        bar = '█' * int(v * 20)\n",
    "        print(f\"  {k:<12} {bar:<20} {v:.3f}\")"
   ]

   "source": [
    "# MAIR+ v2 — Multi-Agent Intelligent Image Restoration\n",
    "## Interactive Demo Notebook\n",
    "\n",
    "> **Paper:** Jiang et al., "Multi-Agent Image Restoration," IJCV 2026  \n",
    "> **Implementation:** Full replication + 12 original contributions (C1–C12)\n",
    "\n",
    "---\n",
    "\n",
    "### What MAIR+ Does\n",
    "1. **Detects** what is wrong with an image (blur, noise, JPEG artifacts, low-light, haze)\n",
    "2. **Plans** which expert model to apply, in what order\n",
    "3. **Applies** restoration in reverse-causal order: `Compression → Imaging → Scene`\n",
    "4. **Evaluates** quality after each stage and rolls back if worse\n",
    "5. **Learns** from past successes using case-based memory\n",
    "6. **Reports** per-stage SSIM/PSNR breakdown"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 1: Setup & Imports ─────────────────────────────────────\n",
    "import os, sys, warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Point to project root\n",
    "PROJECT_ROOT = os.path.abspath('..')\n",
    "if PROJECT_ROOT not in sys.path:\n",
    "    sys.path.insert(0, PROJECT_ROOT)\n",
    "\n",
    "import cv2\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.gridspec as gridspec\n",
    "from IPython.display import display, HTML\n",
    "\n",
    "# MAIR+ imports\n",
    "from core.degradation_detector import detect_degradation\n",
    "from scheduler.scheduler import run_three_stage_scheduler\n",
    "from utils.report_generator import generate_report, generate_html_report\n",
    "\n",
    "plt.rcParams['figure.facecolor'] = '#1a1a2e'\n",
    "plt.rcParams['axes.facecolor']   = '#16213e'\n",
    "plt.rcParams['text.color']       = 'white'\n",
    "plt.rcParams['axes.labelcolor']  = 'white'\n",
    "plt.rcParams['xtick.color']      = 'white'\n",
    "plt.rcParams['ytick.color']      = 'white'\n",
    "\n",
    "print('✅ MAIR+ loaded successfully!')\n",
    "print(f'   Project root: {PROJECT_ROOT}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Architecture Overview\n",
    "\n",
    "```\n",
    "Degraded Input\n",
    "      │\n",
    "      ▼  detect_degradation()  ← C3: DCP haze signal added\n",
    "  [Detector] — blur, noise, jpeg, lowlight, haze, sr\n",
    "      │\n",
    "      ▼  Three-Stage Scheduler (TSF)  ← paper's key contribution\n",
    "  ┌── Stage 1: COMPRESSION ─────────────────────────────────┐\n",
    "  │   experts: swinir_jpeg, opencv_fast_jpeg                │\n",
    "  │   C4: quality gate, C5: spatial guard, C8: thresholds   │\n",
    "  └─────────────────────────────────────────────────────────┘\n",
    "      ↓ C2: re-detect degradation scores\n",
    "  ┌── Stage 2: IMAGING ─────────────────────────────────────┐\n",
    "  │   experts: restormer_deblur, nafnet_lite, swinir_sr     │\n",
    "  │   C9: memory bias, C10: confidence tier, C11: res-rank  │\n",
    "  └─────────────────────────────────────────────────────────┘\n",
    "      ↓ C2: re-detect\n",
    "  ┌── Stage 3: SCENE ───────────────────────────────────────┐\n",
    "  │   experts: zero_dce, dcp_dehaze (C1), freq_derain       │\n",
    "  │   C12: voting ensemble (optional)                        │\n",
    "  └─────────────────────────────────────────────────────────┘\n",
    "      │\n",
    "      ▼\n",
    "  Final Output + Per-Stage Report (C7) + Memory Update (C9)\n",
    "```"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 2: Helper — show_images ───────────────────────────────\n",
    "def bgr2rgb(img):\n",
    "    return cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n",
    "\n",
    "def show_pair(original_path, restored_path, title='Before / After', scores=None):\n",
    "    orig = cv2.imread(original_path)\n",
    "    rest = cv2.imread(restored_path) if restored_path and os.path.exists(restored_path) else None\n",
    "\n",
    "    fig, axes = plt.subplots(1, 2 if rest is not None else 1, figsize=(14, 5))\n",
    "    if rest is None:\n",
    "        axes = [axes]\n",
    "\n",
    "    axes[0].imshow(bgr2rgb(orig))\n",
    "    axes[0].set_title('Original (Degraded)', color='#7ec8e3', fontsize=13, fontweight='bold')\n",
    "    axes[0].axis('off')\n",
    "\n",
    "    if rest is not None:\n",
    "        if orig.shape != rest.shape:\n",
    "            rest = cv2.resize(rest, (orig.shape[1], orig.shape[0]))\n",
    "        axes[1].imshow(bgr2rgb(rest))\n",
    "        score_str = ''\n",
    "        if scores:\n",
    "            score_str = f\"  SSIM={scores.get('ssim', 'N/A')}  PSNR={scores.get('psnr', 'N/A')}dB\"\n",
    "        axes[1].set_title(f'Restored (MAIR+){score_str}', color='#6fe06f', fontsize=13, fontweight='bold')\n",
    "        axes[1].axis('off')\n",
    "\n",
    "    fig.suptitle(title, color='white', fontsize=15, fontweight='bold')\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "print('Helper functions ready.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Create Demo Test Images"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 3: Generate synthetic demo images ─────────────────────\n",
    "demo_dir = os.path.join(PROJECT_ROOT, 'demo_inputs')\n",
    "os.makedirs(demo_dir, exist_ok=True)\n",
    "\n",
    "# Create a clean reference image\n",
    "H, W = 256, 256\n",
    "clean = np.zeros((H, W, 3), dtype=np.uint8)\n",
    "for i in range(H):\n",
    "    for j in range(W):\n",
    "        clean[i, j] = [int(200 * j / W), int(150 * i / H), int(100 + 50 * (i + j) / (H + W))]\n",
    "cv2.circle(clean, (80, 80), 40, (220, 180, 100), -1)\n",
    "cv2.circle(clean, (180, 160), 55, (100, 200, 180), -1)\n",
    "cv2.rectangle(clean, (30, 170), (120, 230), (180, 100, 200), -1)\n",
    "cv2.putText(clean, 'MAIR+', (60, 140), cv2.FONT_HERSHEY_SIMPLEX, 1.0, (255, 255, 255), 2)\n",
    "\n",
    "clean_path = os.path.join(demo_dir, 'clean_reference.png')\n",
    "cv2.imwrite(clean_path, clean)\n",
    "\n",
    "# Apply degradations\n",
    "# 1. Noisy image\n",
    "noise = np.random.normal(0, 35, clean.shape).astype(np.float32)\n",
    "noisy = np.clip(clean.astype(np.float32) + noise, 0, 255).astype(np.uint8)\n",
    "noisy_path = os.path.join(demo_dir, 'noisy_input.png')\n",
    "cv2.imwrite(noisy_path, noisy)\n",
    "\n",
    "# 2. Low-light image\n",
    "lut = np.array([((i / 255.0) ** 3.5) * 255 for i in range(256)], dtype=np.uint8)\n",
    "lowlight = cv2.LUT(clean, lut)\n",
    "lowlight_path = os.path.join(demo_dir, 'lowlight_input.png')\n",
    "cv2.imwrite(lowlight_path, lowlight)\n",
    "\n",
    "# 3. Hazy image (C1 demo)\n",
    "img_f = clean.astype(np.float32) / 255.0\n",
    "gray  = cv2.cvtColor(clean, cv2.COLOR_BGR2GRAY).astype(np.float32) / 255.0\n",
    "depth = 1.0 - gray\n",
    "depth = cv2.GaussianBlur(depth, (0, 0), sigmaX=W // 8)\n",
    "depth = (depth - depth.min()) / (depth.max() - depth.min() + 1e-6)\n",
    "t     = np.exp(-1.5 * depth).astype(np.float32)\n",
    "t     = np.clip(t, 0.1, 1.0)[:, :, np.newaxis]\n",
    "hazy  = np.clip(img_f * t + 0.85 * (1.0 - t), 0, 1)\n",
    "hazy_path = os.path.join(demo_dir, 'hazy_input.png')\n",
    "cv2.imwrite(hazy_path, (hazy * 255).astype(np.uint8))\n",
    "\n",
    "# 4. JPEG-compressed image\n",
    "encode_param = [int(cv2.IMWRITE_JPEG_QUALITY), 10]\n",
    "_, buf = cv2.imencode('.jpg', clean, encode_param)\n",
    "jpeg_img = cv2.imdecode(buf, cv2.IMREAD_COLOR)\n",
    "jpeg_path = os.path.join(demo_dir, 'jpeg_input.png')\n",
    "cv2.imwrite(jpeg_path, jpeg_img)\n",
    "\n",
    "print('✅ Demo images created:')\n",
    "for name, path in [('Clean', clean_path), ('Noisy', noisy_path), \n",
    "                   ('Low-light', lowlight_path), ('Hazy', hazy_path), ('JPEG', jpeg_path)]:\n",
    "    print(f'   {name:<12}: {path}')\n",
    "\n",
    "# Show them\n",
    "fig, axes = plt.subplots(1, 5, figsize=(20, 4))\n",
    "images = [('Clean\\nReference', clean_path), ('Noisy\\n(σ=35)', noisy_path),\n",
    "          ('Low-light\\n(γ=3.5)', lowlight_path), ('Hazy\\n(β=1.5)', hazy_path), ('JPEG\\n(q=10)', jpeg_path)]\n",
    "for ax, (title, path) in zip(axes, images):\n",
    "    img = cv2.imread(path)\n",
    "    ax.imshow(bgr2rgb(img))\n",
    "    ax.set_title(title, color='#7ec8e3', fontsize=11)\n",
    "    ax.axis('off')\n",
    "fig.suptitle('Demo Degradation Types', color='white', fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {

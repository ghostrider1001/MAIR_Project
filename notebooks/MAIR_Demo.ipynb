  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 6: Show noisy → restored comparison ───────────────────\n",
    "from skimage.metrics import structural_similarity as ssim_fn\n",
    "from skimage.metrics import peak_signal_noise_ratio as psnr_fn\n",
    "\n",
    "def get_scores(ref_path, restored_path):\n",
    "    ref  = cv2.cvtColor(cv2.imread(ref_path),  cv2.COLOR_BGR2GRAY)\n",
    "    rest = cv2.cvtColor(cv2.imread(restored_path), cv2.COLOR_BGR2GRAY)\n",
    "    if ref.shape != rest.shape:\n",
    "        rest = cv2.resize(rest, (ref.shape[1], ref.shape[0]))\n",
    "    return {\n",
    "        'ssim': round(float(ssim_fn(ref, rest)), 4),\n",
    "        'psnr': round(float(psnr_fn(ref, rest)), 2),\n",
    "    }\n",
    "\n",
    "if result_noisy['output_path'] and os.path.exists(result_noisy['output_path']):\n",
    "    scores = get_scores(clean_path, result_noisy['output_path'])\n",
    "    show_pair(noisy_path, result_noisy['output_path'],\n",
    "              title='Noise Restoration', scores=scores)\n",
    "    print(f'SSIM vs clean reference: {scores[\"ssim\"]}')\n",
    "    print(f'PSNR vs clean reference: {scores[\"psnr\"]} dB')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [

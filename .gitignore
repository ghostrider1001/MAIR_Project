# ─── Python bytecode ──────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc

# ─── Virtual environments ─────────────────────────────────────
venv/
.venv/
env/
ENV/

# ─── IDE / editor ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── MAIR+ generated outputs ─────────────────────────────────
# Inter-stage pipeline images (temp, not for tracking)
outputs/pipeline_tmp/

# Case memory (C9) — user-specific, grows with usage
outputs/memory/
outputs/memory/case_memory.json

# HTML report cards (C7) — generated per run
outputs/reports/

# Benchmark restored images
outputs/benchmark/
results/benchmark_outputs/

# ─── MAIR+ config (calibrated, not defaults) ─────────────────
# Only ignore if locally calibrated (has calibrated=true set)
# config/thresholds.json   ← kept in repo as default (calibrated=false)

# ─── Model weights (too large for git) ───────────────────────
models/SwinIR/experiments/pretrained_models/*.pth
models/Restormer/Motion_Deblurring/pretrained_models/*.pth
models/Restormer/Deraining/pretrained_models/*.pth
models/Restormer/Deblurring/pretrained_models/*.pth
models/SwinIR/model_zoo/*.pth

# ─── Benchmark datasets (generated locally, not committed) ───
datasets/benchmark/
datasets/calibration/

# ─── Image datasets (too large for git — download separately) ─
datasets/BSDS100/
datasets/BSDS200/
datasets/DIV2K/
datasets/General100/
datasets/Set14/
datasets/T91/
datasets/urban100/
datasets/RESIDE/
datasets/DeSmoke-LAP dataset/
datasets/PG002/
datasets/PG006/
datasets/PG008/
datasets/PG009/
datasets/PG011/
datasets/PG012/
datasets/New folder/
datasets/academic_subsets/
datasets/benchmark_natural/
datasets/historical/
datasets/natural_clean/
datasets/real_world_tests/
datasets/synthetic_smoke/
datasets/synthetic_smoke_sweep/

# ─── Results CSV / JSON (too large for git, use DVC/artifacts) 
results/*.csv
results/*.json

# ─── Notebooks / scratch ─────────────────────────────────────
notebooks/.ipynb_checkpoints/
*.ipynb_checkpoints

# ─── Environment / deps ──────────────────────────────────────
*.egg-info/
dist/
build/

models/

# outputs/ — all generated images, keep fully excluded
outputs/

# results/ — keep benchmark CSVs and JSONs, exclude images/pptx
results/*.png
results/*.pptx
results/dashboard_assets/
results/swinir_jpeg_car_jpeg10/
results/swinir_real_sr_x4/
results/synthetic_benchmark/

# ─── Root-level generated/binary files ───────────────────────
*.pptx
*.png
tmp_*.png
test.png
